# PM Toolkit — Environment Variables
# Copy this file to .env and fill in your values

# Claude API (required for all AI workflows)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Notion API (required for all database operations)
NOTION_API_KEY=your_notion_integration_token

# Google OAuth (required for Drive, Calendar, and Sheets integrations)
# Set up OAuth credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Twitter/X API (optional — only needed for DailyDigest Twitter fetcher)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Gemini API (optional — only needed for ContentVoice image generation)
GEMINI_API_KEY=your_gemini_api_key
